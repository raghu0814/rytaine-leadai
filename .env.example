# ===========================================================================
# RYtaine LeadAI — environment inventory (M0)
# Copy to `.env` and fill values. NEVER commit a real `.env`.
# Run `python scripts/check_env.py` to validate the M0-active block.
# ===========================================================================

# ----- Application ---------------------------------------------------------
APP_ENV=local                 # local | development | staging | production
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# ----- Supabase project ----------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # backend only; bypasses RLS

# ----- Supabase JWT (token verification) -----------------------------------
SUPABASE_JWT_SECRET=<jwt-secret>
SUPABASE_JWT_ALGORITHM=HS256
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_LEEWAY_SECONDS=10

# ----- Database connections (Railway is IPv4-only -> use the pooler host) ---
# App runtime: Supavisor TRANSACTION pooler, port 6543.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Migrations & CI: SESSION pooler, port 5432.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_ECHO=false
DB_STATEMENT_CACHE_SIZE=0     # MUST be 0 on the transaction pooler (port 6543)

# ===========================================================================
# RESERVED — populated in later milestones. Leave blank for M0.
# ---------------------------------------------------------------------------
# M1 (lead ingestion / queue)
# REDIS_URL=
# M2 (RAG)
# OPENAI_API_KEY=
# M3 (voice / telephony)
# ELEVENLABS_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# SARVAM_API_KEY=
# ===========================================================================
