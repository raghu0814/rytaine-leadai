# ---------------------------------------------------------------------------
# RYtaine LeadAI — API service environment template
# Copy to `.env` for local development. Never commit a real `.env`.
# ---------------------------------------------------------------------------

# ----- Application ---------------------------------------------------------
APP_ENV=local                 # local | development | staging | production
DEBUG=false
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
API_V1_PREFIX=/api/v1

# ----- CORS ----------------------------------------------------------------
# Comma-separated list of allowed dashboard origins.
CORS_ORIGINS=http://localhost:3000

# ----- Database (Supabase Postgres) ----------------------------------------
# App runtime uses the Supavisor TRANSACTION pooler (port 6543).
# Plain postgres:// is auto-normalised to the asyncpg driver.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_ECHO=false
# MUST be 0 on the transaction pooler (no prepared statements).
DB_STATEMENT_CACHE_SIZE=0

# ----- Auth (Supabase JWT) -------------------------------------------------
SUPABASE_JWT_SECRET=change-me-in-env
SUPABASE_JWT_ALGORITHM=HS256
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_LEEWAY_SECONDS=10

# ----- Integration tests (M0-7) -----
INTEGRATION_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
